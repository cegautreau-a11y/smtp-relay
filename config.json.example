{
    "web": {
        "host": "0.0.0.0",
        "port": 8025,
        "secret_key": "Change-Me"
    },
    "smtp_listener": {
        "host": "SERVERIP",
        "port": 25,
        "banner_hostname": "server",
        "require_auth": false,
        "enable_tls": false,
        "tls_cert_path": "",
        "tls_key_path": ""
    },
    "relay_destination": {
        "host": "RELAYSERVER",
        "port": 25,
        "use_tls": false,
        "use_starttls": true,
        "auth_user": "",
        "auth_password": "",
        "helo_hostname": "server"
    },
    "limits": {
        "max_message_size_bytes": 26214400,
        "max_recipients_per_message": 5,
        "global_rate_limit_per_hour": 50,
        "allowed_source_ips": [
            "0.0.0.0/0"
        ]
    },
    "queue": {
        "retry_interval_seconds": 300,
        "max_retries": 3
    },
    "logging": {
        "level": "INFO",
        "log_file": "c:\\temp\\smtp.log",
        "log_retention_days": 5,
        "debug_logging": true,
        "debug_log_file": "c:\\temp\\smtp_debug.log",
        "debug_log_max_size": 52428800,
        "debug_log_backup_count": 5
    },
    "database": {
        "path": "smtp_relay.db"
    }
}